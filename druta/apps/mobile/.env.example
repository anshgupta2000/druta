EXPO_PUBLIC_APP_URL=https://your-backend-domain.example.com
EXPO_PUBLIC_BASE_CREATE_USER_CONTENT_URL=https://raw.createusercontent.com
EXPO_PUBLIC_BASE_URL=https://your-backend-domain.example.com
EXPO_PUBLIC_PROXY_BASE_URL=https://your-backend-domain.example.com
EXPO_PUBLIC_CREATE_ENV=PRODUCTION
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_HOST=your-backend-domain.example.com
EXPO_PUBLIC_PROJECT_GROUP_ID=your-project-group-id
EXPO_PUBLIC_UPLOADCARE_PUBLIC_KEY=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_pk_live_value

# Optional: override only the auth WebView origin.
# Use this when testing a local web auth server from a physical phone.
# Example: http://192.168.1.81:4000
# EXPO_PUBLIC_AUTH_BASE_URL=
# EXPO_PUBLIC_AUTH_PROXY_BASE_URL=

# Optional: explicit local in-memory API fallback for local-only development.
# Never enable in QA/staging/prod.
# EXPO_PUBLIC_FORCE_LOCAL_API=true
