ANYTHING_PROJECT_TOKEN=

# Required (Neon/Railway production DB)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Required (generate with: openssl rand -base64 32)
AUTH_SECRET=replace-with-random-secret

# Required (must match deployed backend origin exactly)
# Example: https://druta-backend-production.up.railway.app
AUTH_URL=https://your-backend-domain.example.com

# Optional: allow dev auth cookie flow even when AUTH_* is configured.
# Keep false or unset in production.
# ALLOW_DEV_AUTH=false

# Required for Clerk sign-in when using /account/signin.
# Vite exposes VITE_* values to the browser; the secret key must stay server-only.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace-me
CLERK_SECRET_KEY=sk_test_replace-me

# Optional server-side alias supported by this app's API session verifier.
# CLERK_PUBLISHABLE_KEY=pk_test_replace-me

# Clerk redirect locations for the mounted auth pages.
VITE_CLERK_SIGN_IN_URL=/account/signin
VITE_CLERK_SIGN_UP_URL=/account/signup
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
