ANYTHING_PROJECT_TOKEN=

# Required (Neon/Railway production DB)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Required (generate with: openssl rand -base64 32)
AUTH_SECRET=replace-with-random-secret

# Required (must match deployed backend origin exactly)
# Example: https://druta-backend-production.up.railway.app
AUTH_URL=https://your-backend-domain.example.com

# Optional: allow dev auth cookie flow even when AUTH_* is configured.
# Keep false or unset in production.
# ALLOW_DEV_AUTH=false
